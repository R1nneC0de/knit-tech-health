{
  "name": "knit-tech-health",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @kth/api dev",
    "dev:web": "pnpm --filter @kth/web dev",
    "db:migrate": "pnpm --filter @kth/api db:migrate",
    "db:seed": "pnpm --filter @kth/api db:seed",
    "db:studio": "pnpm --filter @kth/api db:studio",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint"
  },
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/client",
      "@prisma/engines",
      "esbuild"
    ]
  }
}